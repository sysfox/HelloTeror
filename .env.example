# ---- 文章数据（MX-Space core API）----
# MX-Space core 网关地址。推荐填 v3 根：
MXSPACE_API_BASE=https://mx.trfox.top/api/v3
# 也支持直接填完整 posts 端点（代码会自动剥离末尾 /posts）：
# MXSPACE_API_BASE=https://mx.trfox.top/api/v3/posts
#
# 博客前台地址（用于拼装文章 URL）
BLOG_BASE_URL=https://blog.trfox.top

# ---- GitHub 数据 ----
# fine-grained 只读 Token 即可，启用 GraphQL（pinned 仓库 + 贡献统计）。
# 不配置时 Projects / Stats 将使用降级数据，站点仍可正常运行。
GITHUB_TOKEN=
GITHUB_USERNAME=sysfox
